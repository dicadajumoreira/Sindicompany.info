# =============================================================
# Hubstation — environment variables
# Copy this file to .env.local and fill in real values.
# .env.local is gitignored. NEVER commit real keys.
# =============================================================

# --- Supabase (Project Settings → API) ---
# Public values (safe to expose in browser):
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# Server-only secret (NEVER expose to browser):
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# --- Netlify (User Settings → Applications → Personal access tokens) ---
# Used to create subdomains automatically when a new condo is registered.
NETLIFY_ACCESS_TOKEN=nfp_YOUR-PERSONAL-ACCESS-TOKEN
NETLIFY_SITE_ID=YOUR-SITE-ID

# --- App ---
# Root domain (no protocol, no www).
NEXT_PUBLIC_ROOT_DOMAIN=sindico.info

# Used for absolute URLs in emails, etc. (https://www.sindico.info)
NEXT_PUBLIC_APP_URL=https://www.sindico.info

# --- Sindicompany (backoffice editorial em sindicompany.info) ---
NEXT_PUBLIC_SINDICOMPANY_DOMAIN=sindicompany.info

# Senha única de acesso ao backoffice. Compartilhar com a equipe editorial.
SINDICOMPANY_PASSWORD=trocar-esta-senha

# Segredo HMAC para assinar cookies de sessão (mín 16 chars; gere com `openssl rand -base64 32`).
SINDICOMPANY_COOKIE_SECRET=defina-um-segredo-aleatorio-com-pelo-menos-32-caracteres
